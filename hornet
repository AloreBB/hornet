#!/bin/bash
# ============================================================
# 🕸️ HORNET CLI
# ============================================================

set -eo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CONFIG_FILE="$SCRIPT_DIR/config.json"
CREDENTIALS_FILE="${XDG_CONFIG_HOME:-$HOME/.config}/hornet/credentials"
ENV_FILE="$SCRIPT_DIR/.hornet.env"   # legacy fallback
MONITOR="$SCRIPT_DIR/hornet.sh"
BASE_RAW_URL="https://raw.githubusercontent.com/AloreBB/hornet/main"

# ── Colors — Silksong palette (Silk Weave, lospec.com) ────
# #b6595e — Hornet's crimson cloak
# #e2d4b1 — pale silk / wrapping
# #b096bd — muted lavender / Pharloom depths
RED='\033[38;2;182;89;94m'; GREEN='\033[38;2;226;212;177m'; CYAN='\033[38;2;176;150;189m'
BOLD='\033[1m'; RESET='\033[0m'

err()  { gum log --level error "$*" 2>/dev/null || echo -e "${RED}✖ $*${RESET}" >&2; }
ok()   { gum log --level info  "$*" 2>/dev/null || echo -e "${GREEN}✔ $*${RESET}"; }
info() { gum log --level debug "$*" 2>/dev/null || echo -e "${CYAN}→ $*${RESET}"; }

# ── Dependency check ──────────────────────────────────────
if ! command -v gum &>/dev/null; then
    echo -e "${RED}✖ gum is required but not installed.${RESET}"
    echo -e "  Run: ${CYAN}curl -fsSL https://raw.githubusercontent.com/AloreBB/hornet/main/install.sh | bash${RESET}"
    echo -e "  Or:  ${CYAN}https://github.com/charmbracelet/gum#installation${RESET}"
    exit 1
fi
if ! command -v jq &>/dev/null; then
    echo -e "${RED}✖ jq is required but not installed.${RESET}"
    echo -e "  Install with: ${CYAN}sudo apt install jq${RESET}"
    exit 1
fi

# ── jq helpers ────────────────────────────────────────────
require_config() {
    if [[ ! -f "$CONFIG_FILE" ]]; then
        err "config.json not found. Run: hornet init"
        exit 1
    fi
}

jq_get()    { jq -r "$1" "$CONFIG_FILE"; }
jq_update() { local tmp; tmp=$(jq "$1" "$CONFIG_FILE") && echo "$tmp" > "$CONFIG_FILE"; }

# ── UI helpers ────────────────────────────────────────────
header() {
    gum style \
        --border rounded --border-foreground '#553b4f' \
        --padding "0 2" --margin "1 0" \
        "$1"
}

prompt_input()    { gum input --prompt "  ${1}: " --placeholder "${2:-}" --value "${3:-}" --prompt.foreground '#b096bd'; }
prompt_password() { gum input --prompt "  ${1}: " --placeholder "tk_..." --password --prompt.foreground '#b096bd'; }
prompt_choose()   { local h="$1"; shift; gum choose --header "  $h" --cursor "❯ " --cursor.foreground '#b6595e' --selected.foreground '#b96f78' "$@"; }
prompt_confirm()  { gum confirm --affirmative "Yes" --negative "No" --selected.foreground '#e2d4b1' --unselected.foreground '#b096bd' "  $1"; }

prompt_filter() {
    # Fuzzy-pick from a list. Usage: prompt_filter "placeholder" item1 item2 ...
    local placeholder="$1"; shift
    printf '%s\n' "$@" | gum filter --placeholder "$placeholder" --no-limit=false
}

# ── Commands ──────────────────────────────────────────────

cmd_run() {
    require_config
    local log="$SCRIPT_DIR/hornet.log"
    echo
    gum spin --spinner dot --title " Running Hornet scan..." -- \
        bash -c "bash '$MONITOR' >> '$log' 2>&1" || true
    echo

    if [[ -f "$log" ]] && tail -1 "$log" 2>/dev/null | grep -q "Issues: none"; then
        gum style \
            --border rounded --border-foreground '#553b4f' \
            --padding "1 3" --margin "0 1" \
            "$(gum style --bold --foreground '#e2d4b1' "Hallownest está protegido.")" \
            "" \
            "$(gum style --foreground '#b096bd' "He recorrido cada rincón. No hay amenaza.")" \
            "$(gum style --foreground '#b096bd' "Los hilos resisten. El reino permanece en calma.")"
    else
        ok "Scan complete — run 'hornet status' to see results."
    fi
    echo
}

cmd_init() {
    if [[ -f "$CONFIG_FILE" ]]; then
        err "hornet.json already exists. Use 'hornet setup' to configure it."
        exit 1
    fi
    cat > "$CONFIG_FILE" <<'EOF'
{
  "notifications": {
    "url": "",
    "topic": "",
    "icon": ""
  },
  "baseline": {
    "users": [],
    "ssh_keys": [],
    "crontabs": []
  },
  "whitelist": {
    "ports": [22, 80, 443],
    "processes": [],
    "containers": [],
    "extensions": ["so", "py", "sh"]
  }
}
EOF
    chmod 600 "$CONFIG_FILE"
    ok "Created hornet.json"
    echo
    if prompt_confirm "Set up ntfy notifications now?"; then
        _setup_ntfy
    fi
}

cmd_setup() {
    # Auto-create config if missing so setup works on fresh install
    if [[ ! -f "$CONFIG_FILE" ]]; then
        cat > "$CONFIG_FILE" <<'EOF'
{
  "notifications": {
    "url": "https://ntfy.sh",
    "topic": "my-hornet-alerts",
    "icon": ""
  },
  "baseline": {
    "users": [],
    "ssh_keys": [],
    "crontabs": []
  },
  "whitelist": {
    "ports": [22, 80, 443],
    "processes": [],
    "containers": [],
    "extensions": ["so", "py", "sh"]
  }
}
EOF
        chmod 600 "$CONFIG_FILE"
        ok "Created config.json"
    fi

    echo
    header "🕸️  HORNET — Setup"
    local section
    section=$(prompt_choose "What do you want to configure?" \
        "🔔  Notifications (ntfy)" \
        "🔌  Whitelist — ports" \
        "⚙️   Whitelist — processes" \
        "🐳  Whitelist — containers" \
        "📄  Whitelist — file extensions" \
        "✖   Exit") || true
    echo
    case "$section" in
        *"Notifications"*)  _setup_ntfy ;;
        *"ports"*)          _setup_whitelist_interactive "ports" "port" ;;
        *"processes"*)      _setup_whitelist_interactive "processes" "process" ;;
        *"containers"*)     _setup_whitelist_interactive "containers" "container" ;;
        *"extensions"*)     _setup_whitelist_interactive "extensions" "ext" ;;
        *"Exit"*|"") exit 0 ;;
    esac
}

_setup_ntfy() {
    header "🔔  Notifications — ntfy"

    local current_url current_topic current_icon
    current_url=$(jq_get   '.notifications.url   // ""')
    current_topic=$(jq_get '.notifications.topic // ""')
    current_icon=$(jq_get  '.notifications.icon  // ""')

    local url topic icon token
    url=$(prompt_input   "ntfy server URL"        "https://ntfy.sh"  "$current_url")
    topic=$(prompt_input "Topic / channel"         "my-alerts"        "$current_topic")
    icon=$(prompt_input  "Icon URL (optional)"     ""                 "$current_icon")
    token=$(prompt_password "Access token (blank = public ntfy)")

    jq_update \
        ".notifications.url   = \"$url\"   |
         .notifications.topic = \"$topic\" |
         .notifications.icon  = \"$icon\""

    if [[ -n "$token" ]]; then
        mkdir -p "$(dirname "$CREDENTIALS_FILE")"
        printf 'NTFY_TOKEN=%s\n' "$token" > "$CREDENTIALS_FILE"
        chmod 600 "$CREDENTIALS_FILE"
        ok "Token saved to $CREDENTIALS_FILE"
    elif [[ ! -f "$CREDENTIALS_FILE" ]]; then
        mkdir -p "$(dirname "$CREDENTIALS_FILE")"
        printf 'NTFY_TOKEN=\n' > "$CREDENTIALS_FILE"
        chmod 600 "$CREDENTIALS_FILE"
    fi

    ok "Notifications configured."
    echo
    if prompt_confirm "Send a test notification now?"; then
        local test_token=""
        [[ -f "$CREDENTIALS_FILE" ]] && test_token=$(grep '^NTFY_TOKEN=' "$CREDENTIALS_FILE" | cut -d= -f2- || true)
        [[ -z "$test_token" && -f "$ENV_FILE" ]] && test_token=$(grep '^NTFY_TOKEN=' "$ENV_FILE" | cut -d= -f2- || true)
        gum spin --spinner dot --title " Sending test notification..." -- \
            curl -sf --max-time 10 \
                ${test_token:+-H "Authorization: Bearer $test_token"} \
                -H "Title: 🕸️ Hornet — Test" \
                -H "Priority: default" \
                -H "Tags: white_check_mark" \
                -d "Hornet is configured and watching. Hallownest will not fall." \
                "$url/$topic" \
            && ok "Test sent to $url/$topic" \
            || err "Failed to send. Check your URL and token."
    fi
    echo
}

_setup_whitelist_interactive() {
    local json_key="$1" type="$2"

    # Show current values in a table
    local items
    items=$(jq_get ".whitelist.${json_key}[]" 2>/dev/null || true)

    header "Whitelist — $json_key"

    if [[ -n "$items" ]]; then
        { echo "Value"; echo "$items"; } | gum table --border rounded --border.foreground 240
    else
        gum style --foreground 240 --italic "  (empty)"
    fi
    echo

    local action
    action=$(prompt_choose "Action:" "Add" "Remove" "Back")
    case "$action" in
        "Add")
            local val
            val=$(prompt_input "Value to add" "" "")
            [[ -z "$val" ]] && return
            whitelist_add "$type" "$val"
            ;;
        "Remove")
            [[ -z "$items" ]] && { info "Nothing to remove."; return; }
            local val
            val=$(prompt_filter "Search to remove..." $items)
            [[ -z "$val" ]] && return
            whitelist_remove "$type" "$val"
            ;;
        "Back") return ;;
    esac
}

cmd_status() {
    local log="$SCRIPT_DIR/hornet.log"
    echo
    header "🕸️  HORNET — Recent scans"

    if [[ ! -f "$log" ]]; then
        gum style --foreground 240 --italic "  No scans yet. Run 'hornet run' to start."
        echo
        return
    fi

    local entries
    entries=$(tail -20 "$log" | grep -c 'Hornet scan complete' 2>/dev/null || echo 0)

    if [[ "$entries" -eq 0 ]]; then
        gum style --foreground 240 --italic "  No scans recorded in the log yet."
        echo
        return
    fi

    # Build table data: Date | Time | Status
    {
        echo "Date,Time,Status"
        tail -20 "$log" | while IFS= read -r line; do
            local date time issues
            date=$(echo "$line"  | grep -oP '^\[\K[0-9-]+')
            time=$(echo "$line"  | grep -oP '[0-9]{2}:[0-9]{2}:[0-9]{2}')
            issues=$(echo "$line" | grep -oP 'Issues: \K.*')
            echo "${date},${time},${issues}"
        done
    } | gum table --border rounded --border.foreground 240 \
        --widths 12,10,50
    echo
}

cmd_whitelist() {
    require_config
    local subcmd="${1:-}"
    case "$subcmd" in
        list)    whitelist_list ;;
        add)     whitelist_add "${@:2}" ;;
        remove)  whitelist_remove "${@:2}" ;;
        "")
            echo
            header "🕸️  HORNET — Whitelist"
            local section
            section=$(prompt_choose "Which whitelist?" \
                "🔌  Ports" "⚙️   Processes" "🐳  Containers" "📄  Extensions" "Back")
            echo
            case "$section" in
                *"Ports"*)      _setup_whitelist_interactive "ports" "port" ;;
                *"Processes"*)  _setup_whitelist_interactive "processes" "process" ;;
                *"Containers"*) _setup_whitelist_interactive "containers" "container" ;;
                *"Extensions"*) _setup_whitelist_interactive "extensions" "ext" ;;
                "Back") return ;;
            esac
            ;;
        *)
            err "Unknown subcommand: $subcmd"
            echo "Usage: hornet whitelist <list|add|remove> <type> [value]"
            exit 1
            ;;
    esac
}

whitelist_list() {
    echo
    header "🕸️  HORNET — Whitelists"
    {
        echo "Type,Value"
        jq_get '.whitelist.ports[]'      2>/dev/null | while read -r v; do echo "port,$v"; done     || true
        jq_get '.whitelist.processes[]'  2>/dev/null | while read -r v; do echo "process,$v"; done  || true
        jq_get '.whitelist.containers[]' 2>/dev/null | while read -r v; do echo "container,$v"; done || true
        jq_get '.whitelist.extensions[]' 2>/dev/null | while read -r v; do echo "ext,.$v"; done      || true
    } | gum table --border rounded --border.foreground 240 --widths 12,30
    echo
}

whitelist_add() {
    local type="${1:-}" value="${2:-}"
    if [[ -z "$type" || -z "$value" ]]; then
        err "Usage: hornet whitelist add <port|process|container|ext> <value>"
        exit 1
    fi
    case "$type" in
        port)
            [[ "$value" =~ ^[0-9]+$ ]] || { err "Port must be a number."; exit 1; }
            jq_get '.whitelist.ports[]' | grep -qx "$value" && { info "Port $value is already whitelisted."; exit 0; }
            jq_update ".whitelist.ports += [$value] | .whitelist.ports |= sort"
            ok "Added port $value to whitelist."
            ;;
        process|proc)
            jq_get '.whitelist.processes[]' | grep -qx "$value" && { info "Process '$value' is already whitelisted."; exit 0; }
            jq_update ".whitelist.processes += [\"$value\"]"
            ok "Added process '$value' to whitelist."
            ;;
        container)
            jq_get '.whitelist.containers[]' | grep -qx "$value" && { info "Container '$value' is already whitelisted."; exit 0; }
            jq_update ".whitelist.containers += [\"$value\"]"
            ok "Added container '$value' to whitelist."
            ;;
        ext|extension)
            value="${value#.}"
            jq_get '.whitelist.extensions[]' | grep -qx "$value" && { info "Extension '.$value' is already whitelisted."; exit 0; }
            jq_update ".whitelist.extensions += [\"$value\"]"
            ok "Added extension '.$value' to whitelist."
            ;;
        *) err "Unknown type: $type. Valid: port, process, container, ext"; exit 1 ;;
    esac
}

whitelist_remove() {
    local type="${1:-}" value="${2:-}"
    if [[ -z "$type" || -z "$value" ]]; then
        err "Usage: hornet whitelist remove <port|process|container|ext> <value>"
        exit 1
    fi
    case "$type" in
        port)
            jq_update ".whitelist.ports -= [$value]"
            ok "Removed port $value from whitelist."
            ;;
        process|proc)
            jq_update ".whitelist.processes -= [\"$value\"]"
            ok "Removed process '$value' from whitelist."
            ;;
        container)
            jq_update ".whitelist.containers -= [\"$value\"]"
            ok "Removed container '$value' from whitelist."
            ;;
        ext|extension)
            value="${value#.}"
            jq_update ".whitelist.extensions -= [\"$value\"]"
            ok "Removed extension '.$value' from whitelist."
            ;;
        *) err "Unknown type: $type. Valid: port, process, container, ext"; exit 1 ;;
    esac
}

cmd_help() {
    header "🕸️  HORNET — Server Security Monitor"
    gum format -- \
"**Usage:** hornet <command> [options]

**Commands:**
- \`run\`                          Run a security scan now
- \`status\`                       Show recent scan history
- \`setup\`                        Interactive configuration wizard
- \`init\`                         Create a fresh config.json
- \`update\`                       Update Hornet to the latest version
- \`whitelist\`                    Interactive whitelist manager
- \`whitelist list\`               Show all whitelisted values
- \`whitelist add <type> <val>\`   Add to whitelist
- \`whitelist remove <type> <val>\` Remove from whitelist
- \`uninstall\`                    Remove Hornet from this system

**Whitelist types:**
- \`port\`       Open port that should not trigger alerts (e.g. 25565)
- \`process\`    Process name to ignore in high-CPU check (e.g. java)
- \`container\`  Docker container to skip in /tmp binary check
- \`ext\`        File extension to ignore in /tmp checks (e.g. so)

**Config files:**
- \`config.json\`                       Whitelists, ntfy URL/topic/icon, baseline
- \`~/.config/hornet/credentials\`      ntfy token — kept outside the repo

**Notifications:** Hornet sends alerts via ntfy (self-hosted or ntfy.sh).
Run \`hornet setup\` to configure, or edit \`config.json\` directly."
    echo
}

cmd_update() {
    echo
    header "🕸️  HORNET — Update"

    local version_url="${BASE_RAW_URL}/VERSION"
    local local_version_file="$SCRIPT_DIR/VERSION"
    local local_version="unknown"
    [[ -f "$local_version_file" ]] && local_version=$(cat "$local_version_file" | tr -d '[:space:]')

    info "Checking for updates..."
    local remote_version
    remote_version=$(curl -fsSL --max-time 10 \
        -H "Cache-Control: no-cache" \
        -H "Pragma: no-cache" \
        "$version_url" 2>/dev/null | tr -d '[:space:]') || {
        err "Could not reach GitHub. Check your connection."
        exit 1
    }

    echo
    gum style --bold "  Installed: v${local_version}"
    gum style --bold "  Latest:    v${remote_version}"
    echo

    if [[ "$local_version" == "$remote_version" ]]; then
        ok "Hornet is already up to date."
        echo
        return
    fi

    if ! prompt_confirm "Update from v${local_version} → v${remote_version}?"; then
        info "Update cancelled."
        echo
        exit 0
    fi

    echo
    gum spin --spinner dot --title " Downloading Hornet v${remote_version}..." -- bash -c "
        curl -fsSL '${BASE_RAW_URL}/hornet.sh' -o '${SCRIPT_DIR}/hornet.sh.tmp' &&
        curl -fsSL '${BASE_RAW_URL}/hornet'    -o '${SCRIPT_DIR}/hornet.tmp'    &&
        curl -fsSL '${BASE_RAW_URL}/VERSION'   -o '${SCRIPT_DIR}/VERSION.tmp'
    " || { err "Download failed. Try again."; exit 1; }

    mv "$SCRIPT_DIR/hornet.sh.tmp" "$SCRIPT_DIR/hornet.sh"
    mv "$SCRIPT_DIR/hornet.tmp"    "$SCRIPT_DIR/hornet"
    mv "$SCRIPT_DIR/VERSION.tmp"   "$SCRIPT_DIR/VERSION"
    chmod +x "$SCRIPT_DIR/hornet.sh" "$SCRIPT_DIR/hornet"

    ok "Updated to v${remote_version}. Your config.json is untouched."
    echo
}

cmd_uninstall() {
    echo
    header "🕸️  HORNET — Uninstall"
    echo
    gum style --foreground 240 "  This will remove:"
    echo "    • $INSTALL_DIR  (Hornet files + config)"
    echo "    • $BIN_DIR/hornet  (CLI symlink)"
    echo "    • Cron job (if installed)"
    echo

    if ! prompt_confirm "Are you sure you want to uninstall Hornet?"; then
        info "Uninstall cancelled."
        exit 0
    fi

    # Remove cron
    if crontab -l 2>/dev/null | grep -q "hornet.sh"; then
        crontab -l 2>/dev/null | grep -v "hornet.sh" | crontab -
        ok "Cron job removed."
    fi

    # Remove symlink
    local bin="${HORNET_BIN:-$HOME/.local/bin}/hornet"
    [[ -L "$bin" ]] && rm -f "$bin" && ok "Symlink removed."

    # Remove install dir
    local dir="${HORNET_DIR:-$HOME/.hornet}"
    if [[ -d "$dir" ]]; then
        rm -rf "$dir"
        ok "Hornet files removed."
    fi

    echo
    gum style --foreground 240 --italic "  Hallownest falls silent."
    echo
}

# ── Entrypoint ────────────────────────────────────────────
case "${1:-}" in
    run)       cmd_run ;;
    init)      cmd_init ;;
    setup)     cmd_setup ;;
    status)    cmd_status ;;
    update)    cmd_update ;;
    whitelist) cmd_whitelist "${@:2}" ;;
    uninstall) cmd_uninstall ;;
    help|--help|-h) cmd_help ;;
    *) cmd_help ;;
esac
